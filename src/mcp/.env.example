# Address of the Iron Bar boot node gRPC endpoint
IRONBAR_BOOTNODE_ADDRESS=http://localhost:50051

# Port the MCP server listens on (optional — omit when running under Aspire)
IRONBAR_MCP_PORT=5100

# API keys used by the MCP server when forwarding requests to the boot node.
# These should be dedicated keys separate from any keys used by other clients.
# If a key is left empty, the corresponding MCP tool will return an error when called.
# ironbar_list_blocks uses the read key (pass empty to allow unauthenticated listing
# if the boot node permits it; otherwise set to a valid read key).
IRONBAR_MCP_READ_API_KEY=somethingsecret
IRONBAR_MCP_READ_DETAILS_API_KEY=somethingsecret
IRONBAR_MCP_WRITE_API_KEY=somethingsecret
IRONBAR_MCP_ADMIN_API_KEY=somethingsecret
